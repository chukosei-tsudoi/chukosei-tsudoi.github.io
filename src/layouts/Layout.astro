<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const categoryButtons = document.querySelectorAll('.category-button');

        categoryButtons.forEach(button => {
            button.addEventListener('click', () => {
                const content = button.nextElementSibling;
                const icon = button.querySelector('.category-icon');

                // すでに開いている場合は閉じる
                if (content.style.gridTemplateRows === '1fr') {
                    content.style.gridTemplateRows = '0fr';
                    icon.classList.remove('rotate-180');
                } else {
                    /*
                    // 他の開いているカテゴリを閉じる（1つずつしか開けないようにする設定）
                    document.querySelectorAll('.category-content').forEach(c => c.style.gridTemplateRows = '0fr');
                    document.querySelectorAll('.category-icon').forEach(i => i.classList.remove('rotate-180'));
                    */
                    // クリックしたカテゴリを開く
                    content.style.gridTemplateRows = '1fr';
                    icon.classList.add('rotate-180');
                }
            });
        });
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // 「as HTMLElement」を付けることで、TypeScriptに型を確信させます
        const menuBtn = document.getElementById('menu-btn') as HTMLElement;
        const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
        const line1 = document.getElementById('line-1') as HTMLElement;
        const line2 = document.getElementById('line-2') as HTMLElement;
        const line3 = document.getElementById('line-3') as HTMLElement;
        const navLinks = document.querySelectorAll('.nav-link');

        // もし要素が一つでも欠けていたら、エラーを起こさず静かに終了させる
        if (!menuBtn || !mobileMenu || !line1 || !line2 || !line3) return;

        let isMenuOpen = false;

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;
            
            // mobileMenuがnullでないことは上のif文で確定しているので、エラーになりません
            if (isMenuOpen) {
                mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
                line1.style.transform = "rotate(45deg) translate(2px, -1px)";
                line2.style.opacity = "0";
                line3.style.transform = "rotate(-45deg) translate(2px, 1px)";
                document.body.style.overflow = "hidden";
            } else {
                mobileMenu.classList.add('opacity-0', 'pointer-events-none');
                line1.style.transform = "none";
                line2.style.opacity = "1";
                line3.style.transform = "none";
                document.body.style.overflow = "auto";
            }
        }

        menuBtn.addEventListener('click', toggleMenu);

        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (isMenuOpen) toggleMenu();
            });
        });
    });
</script>

</html>