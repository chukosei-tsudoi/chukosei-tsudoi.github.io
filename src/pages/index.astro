---
import Layout from '../layouts/Layout.astro';

import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
// 最新順に並び替え
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const title = "全国言友会 吃音のある中高生交流会";
---

<Layout title={title}>
    
    <section class="relative md:h-[500px] lg:h-[700px] overflow-hidden bg-slate-900">
    <div class="bg-[#a5ddff] flex flex-col h-full md:hidden">
        <img src="/images/top1_sm.png" alt="" class="w-full object-cover" />
        <img src="/images/top2_sm.png" alt="" class="w-full object-cover" />
    </div>

    <div class="hidden md:block h-full w-full">
        <img src="/images/top1.png" alt="" class="h-full w-full object-cover" />
    </div>

</section>

<section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-8 md:px-8 justify-center">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-center">
            
            <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-6 justify-self-center">
                <img 
                    src="/images/zenkoku_poster1.png" 
                    alt="ポスター1" 
                    class="w-full h-auto object-cover rounded-xl md:rounded-2xl"
                />
                <img 
                    src="/images/zenkoku_poster2.png" 
                    alt="ポスター2" 
                    class="w-full h-auto object-cover rounded-xl md:rounded-2xl" 
                />
            </div>

            <div class="lg:col-span-5 flex flex-col space-y-4">
                <div>
                    <h2 class="text-blue-700 font-bold text-xl uppercase mb-4">
                        ▶︎次回の交流会
                    </h2>
                    <h3 class="text-2xl md:text-3xl font-bold text-black tracking-tight leading-tight">
                        全国言友会 吃音のある中高生交流会 <br>in 第8回うぃーすた全国交流会
                    </h3>
                </div>
                
                <div class="font-medium text-base md:text-lg text-black leading-relaxed space-y-4">
                    <p>
                        日時：2026年7月18日(土)・19日(日)<br>
                        開催地：大阪
                    </p>
                    <p>
                        ビンゴをしたり、BBQをしたり、花火をしたり、<br>
                        吃音のある中高生同士で楽しみましょう🌟
                    </p>
                    <p>
                        詳細は特設サイトをご覧ください👇
                    </p>
                </div>

                <div class="pt-2">
                    <a href="https://www.westu-zenkoku.com/chukosei/" class="inline-flex items-center justify-center px-8 py-3 font-bold text-white bg-red-600 rounded-full hover:bg-red-700 transition shadow-sm hover:shadow-lg text-center">
                        特設サイトはこちら
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>

    <section class="bg-[#a5ddff] py-10 max-md:pb-4 md:py-20 px-6">
        <div class="max-w-6xl mx-auto grid max-md:m-3 md:grid-cols-2 gap-10 md:gap-16 items-center">
            
            <div class="order-1 md:order-1">
    <div class="border-3 border-white rounded-3xl p-8 md:p-12 md:ml-14 relative overflow-hidden group">
        

        <div class="relative z-10">
            <p class="text-white font-bold leading-loose text-base md:text-xl">
                吃音のある人は100人に1人。
                <br>
全国には吃音のある中高生が沢山います。
<br>
お互いの経験を共有し、悩みや喜びを分かち合う仲間を見つけませんか？
<br>
思春期の困りごと，一緒に乗り越えよう。
<br>
吃音のある中高生交流会で、同年代の吃音のある友達と心のつながりを感じてください。
            </p>
        </div>
    </div>
</div>

            <div class="order-1 md:order-2">
                <div class="relative">
                    <div class="relative">
                        <img 
                            src="/images/top2.png" 
                            alt="交流会の様子イメージ" 
                            class="w-full h-auto object-cover"
                        />
                    </div>
                </div>
            </div>

        </div>
    </section>

    <section id="about" class="py-16 md:py-24 max-w-6xl mx-auto px-8 md:px-6">
        <div class="grid md:grid-cols-2 gap-8 md:gap-16 items-center">
            
            <div class="flex flex-col justify-center space-y-10 md:ml-14">
                
                <div>
                    <h3 class="w-fit text-xl md:text-2xl font-bold mb-4 text-sky-500 pb-2 pr-2">
                        全国に吃音のある仲間を増やす
                    </h3>
                    <p class="text-base md:text-lg font-bold text-blue-900 leading-relaxed">
                        吃音のことや趣味のことを語り合ったり、みんなでゲームをしたり、吃音のある仲間同士で楽しく過ごせる時間にします。
                    </p>
                </div>

                <div>
                    <h3 class="w-fit text-xl md:text-2xl font-bold mb-4 text-sky-500 pb-2 pr-2">
                        オンラインによるグループトーク
                    </h3>
                    <p class="text-base md:text-lg font-bold text-blue-900 leading-relaxed">
                        同年代の少人数グループ（4名程度）でZoomでお話します。ニックネームで参加してください。チャットのみでの参加も可能です。上手く話す必要はありません。もちろん時間が掛かっても大丈夫。安心して参加して下さい。
                    </p>
                </div>

                <div>
                    <h3 class="w-fit text-xl md:text-2xl font-bold mb-4 text-sky-500 pb-2 pr-2">
                        吃音のある先輩のサポート
                    </h3>
                    <p class="text-base md:text-lg font-bold text-blue-900 leading-relaxed">
                        吃音のある大学生、若手社会人、ことばの教室の先生、言語聴覚士が司会を行いグループトークをサポートします。
                    </p>
                </div>

            </div>

            <div class="relative w-full max-w-md mx-auto md:ml-auto overflow-hidden max-md:mx-4 mt-8 md:mt-0">
    <img 
        src="/images/top3.png" 
        alt="" 
        class="w-full h-auto object-cover rounded-2xl shadow-sm"
    />
</div>

        </div>
    </section>

    <section id="voice" class="bg-sky-100 py-16 md:py-24 relative overflow-hidden">

        <div class="max-w-6xl mx-auto px-10 md:px-6 relative z-10">
            <h3 class="w-fit mx-auto text-2xl font-bold mb-16 text-slate-900 border-b-4 border-blue-600 pb-3 px-2">
    参加者の声
</h3>
            <div class="grid md:grid-cols-3 max-md:pb-4 gap-16 md:gap-8">

                <div class="relative max-w-lg mx-auto">
                    <div class="bg-white p-8 pb-6 rounded-3xl relative">
                        <div class="text-4xl text-black absolute top-4 left-4">“</div>
        
                        <p class="text-black font-medium leading-relaxed relative z-10 px-2">
                            とても楽しく、皆さんと話せて勇気が出ました。皆さんの経験談などを聞かせていただけて、本当に励まされました。
                        </p>
                        <div class="text-4xl text-black absolute top-4 right-4">”</div>
                        <div class="relative z-10 text-right">
                            <span class="text-sm font-bold text-black px-3 py-1 rounded-full">
                                高校1年生・男性
                            </span>
                        </div>

                        <div class="absolute -bottom-[28px] right-10 w-8 h-10 bg-white border-l border-r border-slate-100 -rotate-20" 
                            style="clip-path: polygon(0 0, 100% 0, 50% 100%);">
                        </div>
                    </div>
                </div>

                <div class="relative max-w-lg mx-auto">
                    <div class="bg-white p-8 pb-6 rounded-3xl relative">
                        <div class="text-4xl text-black absolute top-4 left-4">“</div>
        
                        <p class="text-black font-medium leading-relaxed relative z-10 px-2">
                            45分が一瞬に感じるほど楽しい時間を過ごさせて頂きました。またこのような機会に積極的に参加したいです！
                        </p>
                        <div class="text-4xl text-black absolute top-4 right-4">”</div>
                        <div class="relative z-10 text-right">
                            <span class="text-sm font-bold text-black px-3 py-1 rounded-full">
                                中学2年生・女性
                            </span>
                        </div>

                        <div class="absolute -bottom-[28px] right-10 w-8 h-10 bg-white border-l border-r border-slate-100 -rotate-20" 
                            style="clip-path: polygon(0 0, 100% 0, 50% 100%);">
                        </div>
                    </div>
                </div>

                <div class="relative max-w-lg mx-auto">
                    <div class="bg-white p-8 pb-6 rounded-3xl relative">
                        <div class="text-4xl text-black absolute top-4 left-4">“</div>
        
                        <p class="text-black font-medium leading-relaxed relative z-10 px-2">
                            身近に吃音の人がいなかったので、『自分と同じ人がいる』と思えて安心しました。新学期も頑張れそうです。
                        </p>
                        <div class="text-4xl text-black absolute top-4 right-4">”</div>
                        <div class="relative z-10 text-right">
                            <span class="text-sm font-bold text-black px-3 py-1 rounded-full">
                                高校2年生・女性
                            </span>
                        </div>

                        <div class="absolute -bottom-[28px] right-10 w-8 h-10 bg-white border-l border-r border-slate-100 -rotate-20" 
                            style="clip-path: polygon(0 0, 100% 0, 50% 100%);">
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="py-16 md:py-24 max-w-6xl mx-auto px-6">
    <h3 class="w-fit mx-auto text-2xl md:text-2xl font-bold mb-16 text-slate-900 border-b-4 border-blue-600 pb-3 px-2">
        運営メンバー紹介
    </h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
        
        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__54378512.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">青木 瑞樹</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">大学院生</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                大学院の博士課程で吃音の勉強をしています。<br>
                私も当事者で5歳ごろから吃音があります。小学校の頃はことばがなかなか出ない「難発」が主でしたが，今はことばを繰り返す「連発」が主な症状です。吃音の勉強をしたり，当事者と関わることで前向きに生活できています。
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__7684109.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">西尾 優人</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">おおさか結言友会</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                おおさか結言友会で会長をしています。物心ついた頃からどもっていた記憶があり、少しずつ隠すようになり難発に変わりました。元々は話すことを避けていましたが、今では相談に乗ったり話すことが中心となるお仕事をしています。交流会ではみんなが仲間です！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__293560331.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">たぶち せいな</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">社会人</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                物心ついたときから吃音があり社会人1年目の今でも悩む日々が続いています。中高生の頃は誰にも相談できず一番苦しんだ時期でもありました。ですがこの交流会では同じ気持ちの仲間に会えることができます。ぜひ一緒に楽しい時間を過ごしましょう〜！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/8dda504721f3999781e1fa633c35db25.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">福島 廉</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">高校教員</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                私は、高校生の頃から吃音(難発)があります。今現在は、私立高校で教員をしております。自身の生きづらさと、他人の生きづらさを大切にできる生徒を育てていきたいと思っています。同世代の仲間達と話してみませんか〜？皆さんとお会いできるのを楽しみにしております！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/4E1794C3-EA59-47B0-88C0-727D1D374BE5.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">稲田 悠人</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">社会人</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                知らない人たちばかりで、最初は緊張するよね。でも大丈夫！みんな吃音のことについて理解のある優しい人たちばかりだよ！堅くない会だから、まずは楽しもうね！みんなとお話しするのを楽しみにしてます！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/73A831BF-4C45-469F-9EE5-6278204EE715.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">サオリ</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">社会人</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                はじめまして。私にも小さい頃から吃音があります。今の学校生活について、将来のことについて、何でも大丈夫です。皆さんとお話できるのを楽しみにしています！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__341196806.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">あきら</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">大学院生</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                僕自身、中高生のとき特に吃音で悩んでおり、誰にも相談できずにいました。同じ吃音をもつ仲間と話したり、悩みを共有したりしませんか？交流会でお会いできることを楽しみにしています！
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__341196808.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">しおり</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">社会人</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                ここでは、うまく話せなかったり、沈黙が続いたりしても大丈夫です。私自身も毎回ドキドキしながらファシリテーターをしています笑。今、吃音に悩んでいる人も、そうででない人も、ぜひお気軽にご参加ください♪
            </p>
        </div>

        <div class="text-center group flex flex-col items-center">
            <div class="relative w-36 h-36 mx-auto mb-5 rounded-full overflow-hidden transition-transform">
                <img src="/images/S__341196809.jpg" alt="" class="w-full h-full object-cover">
            </div>
            <p class="font-bold text-lg text-slate-900">みきひろ</p>
            <p class="text-base text-blue-600 font-medium mt-1 mb-4">大学院生</p>
            <p class="text-left text-base font-medium text-black leading-relaxed max-w-[300px]">
                私も吃音で悩むことが多かったです。しかし、吃音の仲間と出会い、少しずつ自分と向き合える時間が増えていきました。交流会をみなさんと一緒に楽しく過ごせる時間にしたいです。よろしくお願いします！
            </p>
        </div>

    </div>
    <div class="mt-16 text-center">
            <p class="inline-block px-7 py-3 bg-slate-200 text-black rounded-full text-base md:text-base font-medium">
                他、数名のスタッフが<br class="md:hidden" />ファシリテーターを務めます
            </p>
        </div>
</section>

   <section id="news" class="bg-slate-200 py-16 md:py-24 relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-10 md:px-6 relative z-10">
        <h3 class="w-fit mx-auto text-2xl font-bold mb-10 text-slate-900 border-b-4 border-blue-600 pb-3 px-2">
            お知らせ
        </h3>

        <div class="divide-y divide-slate-300"> {latestPosts.map((post) => (
                <a href={`/posts/${post.id}`} class="group block py-6 transition-colors">
                    <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-6">
                        
                        <div class="flex items-center gap-4 shrink-0">
                            <time class="text-base text-black font-medium">
                                {post.data.date.toLocaleDateString('ja-JP').replace(/\//g, '.')}
                            </time>
                            
                            <span class="w-fit px-3 py-1 text-xs font-bold text-blue-600 bg-blue-50 rounded-full">
                                {post.data.tag}
                            </span>
                        </div>
                        
                        <h4 class="flex-1 text-lg font-bold text-black group-hover:text-blue-600 group-hover:underline decoration-2 underline-offset-4 transition-colors">
                            {post.data.title}
                        </h4>

                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

    <section id="qa" class="bg-slate-50 py-16 md:py-24">
        <div class="max-w-4xl mx-auto px-6">
             <h3 class="w-fit mx-auto text-2xl md:text-2xl font-bold mb-16 text-slate-900 border-b-4 border-blue-600 pb-3 px-2">
    よくある質問
</h3>

            <div class="space-y-4">
                
                <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                    <button class="category-button cursor-pointer w-full px-6 py-5 md:px-8 md:py-6 text-left flex justify-between items-center hover:bg-slate-50 transition-colors focus:outline-none">
                        <h4 class="text-base md:text-lg font-bold text-slate-800">
                            A. 申し込みについて
                        </h4>
                        <svg class="category-icon w-5 h-5 md:w-6 md:h-6 text-slate-400 transition-transform duration-300 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>
                    
                    <div class="category-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
                        <div class="overflow-hidden">
                            <div class="px-6 pb-6 md:px-8 md:pb-8 pt-8 border-t border-slate-100 space-y-8 mt-2">
                                
                                <div>
                                    <h4 class="font-bold text-blue-600 flex items-start mb-2">
                                        <span class="mr-1 leading-none mt-1 shrink-0 w-10 font-black">A-1.</span>
                                        <span class="leading-relaxed">申し込みはどうすればよいですか？</span>
                                    </h4>
                                    <p class="text-sm md:text-base text-black font-medium leading-relaxed ml-11">
                                        開催日程&申込ページよりお願いします。
                                    </p>
                                </div>

                                <div>
                                    <h4 class="font-bold text-blue-600 flex items-start mb-2">
                                        <span class="mr-1 leading-none mt-1 shrink-0 w-10 font-black">A-2.</span>
                                        <span class="leading-relaxed">キャンセルしたい時・予約を変更したい時はどうすればよいですか？</span>
                                    </h4>
                                    <p class="text-sm md:text-base text-black font-medium leading-relaxed ml-11">
                                        お問い合わせページよりお願いします。
                                    </p>
                                </div>

                                <div>
                                    <h4 class="font-bold text-blue-600 flex items-start mb-2">
                                        <span class="mr-1 leading-none mt-1 shrink-0 w-10 font-black">A-3.</span>
                                        <span class="leading-relaxed">申し込み期限はありますか？</span>
                                    </h4>
                                    <p class="text-sm md:text-base text-black font-medium leading-relaxed ml-11">
                                        運営の準備の都合上、10日間前までにお申込みください。詳しくは開催日程をご覧ください。
                                    </p>
                                </div>

                                <div>
                                    <h4 class="font-bold text-blue-600 flex items-start mb-2">
                                        <span class="mr-1 leading-none mt-1 shrink-0 w-10 font-black">A-4.</span>
                                        <span class="leading-relaxed">Googleフォームから申し込みができませんがどうしたらよいですか？</span>
                                    </h4>
